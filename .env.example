# =============================================================================
# Atlas Econômico do Vale do Paraíba — Variáveis de Ambiente
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores no arquivo .env
#   3. NUNCA commite o arquivo .env — ele está no .gitignore
# =============================================================================

# --- Google Cloud Platform ---
GCP_PROJECT_ID=seu-projeto-gcp
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=credentials/gcp-service-account.json

# --- BigQuery ---
BQ_DATASET_BRONZE=bronze_vale_paraiba
BQ_DATASET_SILVER=silver_vale_paraiba
BQ_DATASET_GOLD=gold_vale_paraiba
BQ_LOCATION=US

# --- Google Cloud Storage ---
GCS_BUCKET=atlas-vale-paraiba-datalake
GCS_RAW_PREFIX=raw/
GCS_PROCESSED_PREFIX=processed/

# --- Configurações de Coleta ---
# Municípios alvo (códigos IBGE) — separados por vírgula
TARGET_MUNICIPALITIES=3549904,3554102,3524402,3299606,3537107,3517303,3536505,3520400,3521606,3549300,3472203,3537305

# Período de análise
START_YEAR=2015
END_YEAR=2024

# --- Controle de Execução ---
LOG_LEVEL=INFO
MAX_RETRIES=3
REQUEST_TIMEOUT_SECONDS=30
